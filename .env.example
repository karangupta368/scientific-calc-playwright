# Application under test (directory URL; tests open index.html relative to this)
BASE_URL=https://rbihubcodechallenge.github.io/calculator/

# Run browsers headless (true | false)
HEADLESS=true

# Parallel workers (leave empty for Playwright default: ~50% of CPU cores)
# WORKERS=4

# Default command timeout in milliseconds
# TIMEOUT=30000

# Browser projects to run: chromium, firefox, webkit (comma-separated)
# CI (GitHub Actions) sets PROJECTS=chromium — install only Chromium in the pipeline
# Local default when unset: chromium,firefox,webkit
# On macOS 14, WebKit is "frozen" — use PROJECTS=chromium,firefox locally if you prefer
# PROJECTS=chromium,firefox,webkit
